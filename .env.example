# --- Core app ---
PORT=3000
DB_PATH=./data/sn110-tracker.sqlite

# Polling
POLL_INTERVAL_MINUTES=60

# Taostats auth
TAOSTATS_API_KEY=
# or, if you need to pass a full auth header:
TAOSTATS_AUTH_HEADER=
# Optional feature flag for showing the admin drawer and protecting admin POST routes:
TAOSTATS_ADMIN_API_KEY=

# Taostats base URLs
TAOSTATS_BASE_URL=https://api.taostats.io
TAOSTATS_PUBLIC_BASE_URL=https://taostats.io

# Free-tier API budget
TAOSTATS_API_MAX_REQUESTS_PER_MINUTE=5

# Backfill defaults
TAOSTATS_BACKFILL_DAYS=30
TAOSTATS_BACKFILL_FREQUENCY=by_hour
TAOSTATS_BACKFILL_OVERWRITE=true
TAOSTATS_BACKFILL_ON_STARTUP=false

# Wallet 1
TAOSTATS_WALLET_1_NAME=Miner
TAOSTATS_WALLET_1_COLDKEY=<your-wallet-1-coldkey-ss58>
# Backward-compatible alias:
# TAOSTATS_WALLET_1_SS58=<your-wallet-1-coldkey-ss58>
TAOSTATS_WALLET_1_NETWORK=finney

# Optional hotkeys for Wallet 1
TAOSTATS_WALLET_1_HOTKEY_1_NAME=SN110 Miner
TAOSTATS_WALLET_1_HOTKEY_1_SS58=<your-wallet-1-hotkey-1-ss58>
TAOSTATS_WALLET_1_HOTKEY_1_NETUID=110

# Wallet 2
TAOSTATS_WALLET_2_NAME=Validator
TAOSTATS_WALLET_2_COLDKEY=<your-wallet-2-coldkey-ss58>
TAOSTATS_WALLET_2_NETWORK=finney

# Optional hotkeys for Wallet 2
TAOSTATS_WALLET_2_HOTKEY_1_NAME=Green Compute
TAOSTATS_WALLET_2_HOTKEY_1_SS58=<your-wallet-2-hotkey-1-ss58>
TAOSTATS_WALLET_2_HOTKEY_1_NETUID=110
