# Server
PORT=3000

# Taostats subnet target
TAOSTATS_NETUID=110

# Taostats auth
# Use either TAOSTATS_API_KEY or set TAOSTATS_AUTH_HEADER to the full Authorization value.
TAOSTATS_API_KEY=
TAOSTATS_AUTH_HEADER=

# Free-tier budget: 5 requests per minute by default
TAOSTATS_API_MAX_REQUESTS_PER_MINUTE=5

# Historical backfill mode
TAOSTATS_BACKFILL_DAYS=0
TAOSTATS_BACKFILL_FREQUENCY=by_hour
TAOSTATS_BACKFILL_ON_STARTUP=false
TAOSTATS_BACKFILL_OVERWRITE=true

# Tracked wallets (repeat with incrementing indexes)
TAOSTATS_WALLET_1_NAME=Treasury
TAOSTATS_WALLET_1_SS58=5WalletAlpha123456789ABCDEFGH
TAOSTATS_WALLET_1_NETWORK=finney
TAOSTATS_WALLET_2_NAME=Ops
TAOSTATS_WALLET_2_SS58=5WalletBeta123456789ABCDEFGH
TAOSTATS_WALLET_2_NETWORK=finney

# Taostats endpoints
TAOSTATS_BASE_URL=https://api.taostats.io
TAOSTATS_PUBLIC_BASE_URL=https://taostats.io

# Local storage
DB_PATH=./data/sn110-tracker.sqlite

# Ingest cadence
# Supported dashboard choices: 60, 120, 240 minutes
POLL_INTERVAL_MINUTES=60
